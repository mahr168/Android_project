# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file - contains SDK path, do not commit
local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio
*.iml
.idea/
.DS_Store

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# Keystore files - NEVER commit these to version control
*.jks
*.keystore

# Google Services (if using Firebase)
google-services.json

# Signing reports
*.keystore
signing-report.txt
